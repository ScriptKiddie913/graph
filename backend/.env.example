# Telegram Bot Configuration
BOT_TOKEN=your_bot_token_here
CHAT_ID=your_chat_id_here

# Server Configuration
PORT=3001

# Graph Configuration (optional)
MAX_NODES=500000

# Webhook URL (optional - for production deployments)
# WEBHOOK_URL=https://your-backend.onrender.com

# No-store mode (optional)
# NO_STORE_MODE=true

# Telethon mode (optional - fetch channel history directly)
# TELETHON_MODE=true
# TELETHON_PYTHON=python3
# TG_API_ID=123456
# TG_API_HASH=your_api_hash
# TG_CHANNEL=@your_channel_username_or_id
# TG_SESSION=graph_intel
# TG_STRING_SESSION=your_generated_string_session
